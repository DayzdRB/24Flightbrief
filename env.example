# Copy this to a real .env.local for local dev, or set each of these
# in your Vercel project's Settings -> Environment Variables.
# NEVER commit a file containing your real secrets to GitHub.

# From the Discord Developer Portal -> your app -> OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must exactly match a redirect URI registered in the Discord Developer Portal
DISCORD_REDIRECT_URI=https://your-deployed-domain.vercel.app/api/auth/callback

# Any long random string you generate yourself (used to sign session cookies)
SESSION_SECRET=

# From Upstash: your Redis database -> REST API section
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
